{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://presentation-shared/schemas/redteam/expected-outcome_v1.schema.json",
  "title": "ExpectedOutcomeV1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "action",
    "safe_response_requirements",
    "must_not_do",
    "minimum_controls"
  ],
  "properties": {
    "action": {
      "type": "string",
      "enum": [
        "block",
        "sanitize_and_continue",
        "refuse_and_explain",
        "escalate_to_hitl",
        "continue_with_safe_output"
      ]
    },
    "safe_response_requirements": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 3 }
    },
    "must_not_do": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 3 }
    },
    "minimum_controls": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": [
          "policy_filtering",
          "schema_validation",
          "citation_verification",
          "tenant_isolation_check",
          "renderer_sanitization",
          "hitl_gate",
          "rate_limit_or_budget_guard"
        ]
      }
    },
    "notes": {
      "type": "string",
      "minLength": 3
    }
  }
}
