{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://presentation-shared/schemas/redteam/attack-category-taxonomy_v1.schema.json",
  "title": "AttackCategoryTaxonomyV1",
  "type": "object",
  "additionalProperties": false,
  "required": ["taxonomy_id", "version", "categories"],
  "properties": {
    "taxonomy_id": { "type": "string", "minLength": 3 },
    "version": { "type": "string", "pattern": "^v[0-9]+$" },
    "categories": {
      "type": "array",
      "minItems": 10,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "name",
          "description",
          "default_severity",
          "examples"
        ],
        "properties": {
          "id": { "type": "string", "minLength": 3 },
          "name": { "type": "string", "minLength": 3 },
          "description": { "type": "string", "minLength": 8 },
          "default_severity": {
            "type": "string",
            "enum": ["low", "medium", "high", "critical"]
          },
          "examples": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 5 }
          }
        }
      }
    }
  }
}
