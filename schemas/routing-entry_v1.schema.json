{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Routing Entry v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["description", "model_keys"],
  "properties": {
    "description": {"type": "string", "minLength": 1},
    "model_keys": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1}
    }
  }
}
