{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://presentation-shared/schemas/session-api-contracts_v1.schema.json",
  "title": "Session Oriented API Contracts v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "CreateSessionRequest",
    "CreateSessionResponse",
    "RegisterInputRequest",
    "RegisterInputResponse",
    "UnderstandingResponse",
    "ApproveUnderstandingRequest",
    "ApprovalResponse",
    "QuestionListResponse",
    "AnswerQuestionRequest",
    "QuestionAnswerResponse",
    "GenerateOutlineRequest",
    "OutlineResponse",
    "ApproveOutlineRequest",
    "OutlineApprovalResponse",
    "GenerateDeckSpecRequest",
    "DeckSpecResponse"
  ],
  "properties": {
    "CreateSessionRequest": {"$ref": "#/$defs/CreateSessionRequest"},
    "CreateSessionResponse": {"$ref": "#/$defs/CreateSessionResponse"},
    "RegisterInputRequest": {"$ref": "#/$defs/RegisterInputRequest"},
    "RegisterInputResponse": {"$ref": "#/$defs/RegisterInputResponse"},
    "UnderstandingResponse": {"$ref": "#/$defs/UnderstandingResponse"},
    "ApproveUnderstandingRequest": {"$ref": "#/$defs/ApprovalRequest"},
    "ApprovalResponse": {"$ref": "#/$defs/ApprovalResponse"},
    "QuestionListResponse": {"$ref": "#/$defs/QuestionListResponse"},
    "AnswerQuestionRequest": {"$ref": "#/$defs/QuestionAnswerRequest"},
    "QuestionAnswerResponse": {"$ref": "#/$defs/QuestionAnswerResponse"},
    "GenerateOutlineRequest": {"$ref": "#/$defs/GenerateArtifactRequest"},
    "OutlineResponse": {"$ref": "#/$defs/OutlineResponse"},
    "ApproveOutlineRequest": {"$ref": "#/$defs/ApprovalRequest"},
    "OutlineApprovalResponse": {"$ref": "#/$defs/OutlineApprovalResponse"},
    "GenerateDeckSpecRequest": {"$ref": "#/$defs/GenerateArtifactRequest"},
    "DeckSpecResponse": {"$ref": "#/$defs/DeckSpecResponse"}
  },
  "$defs": {
    "Status": {
      "type": "string",
      "enum": [
        "open",
        "needs_clarification",
        "ready_for_approval",
        "approved",
        "questions_pending",
        "questions_resolved",
        "outline_draft",
        "outline_approved",
        "deck_spec_ready",
        "input_registered",
        "question_answered"
      ]
    },
    "ContextFields": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "actor_id": {"type": "string", "minLength": 1},
        "tenant_id": {"type": "string", "minLength": 1},
        "project_id": {"type": ["string", "null"], "minLength": 1}
      }
    },
    "CreateSessionRequest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["actor_id", "tenant_id"],
      "properties": {
        "actor_id": {"type": "string", "minLength": 1},
        "tenant_id": {"type": "string", "minLength": 1},
        "project_id": {"type": ["string", "null"], "minLength": 1}
      }
    },
    "CreateSessionResponse": {
      "type": "object",
      "additionalProperties": false,
      "required": ["session_id", "thread_id", "actor_id", "tenant_id", "status"],
      "properties": {
        "session_id": {"type": "string", "pattern": "^sess-[A-Za-z0-9_-]{8,}$"},
        "thread_id": {"type": "string", "minLength": 1},
        "actor_id": {"type": "string", "minLength": 1},
        "tenant_id": {"type": "string", "minLength": 1},
        "project_id": {"type": ["string", "null"], "minLength": 1},
        "status": {"const": "open"}
      }
    },
    "RegisterInputRequest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["content", "actor_id", "tenant_id"],
      "properties": {
        "kind": {"type": "string", "enum": ["text"]},
        "content": {"type": "string", "minLength": 1},
        "actor_id": {"type": "string", "minLength": 1},
        "tenant_id": {"type": "string", "minLength": 1},
        "project_id": {"type": ["string", "null"], "minLength": 1}
      }
    },
    "RegisterInputResponse": {
      "type": "object",
      "additionalProperties": false,
      "required": ["input_id", "session_id", "thread_id", "actor_id", "tenant_id", "status"],
      "properties": {
        "input_id": {"type": "string", "minLength": 1},
        "session_id": {"type": "string"},
        "thread_id": {"type": "string"},
        "actor_id": {"type": "string"},
        "tenant_id": {"type": "string"},
        "project_id": {"type": ["string", "null"]},
        "status": {"const": "input_registered"}
      }
    },
    "UnderstandingResponse": {
      "type": "object",
      "additionalProperties": false,
      "required": ["session_id", "thread_id", "understanding", "sufficiency", "default_proposal", "approved", "actor_id", "tenant_id", "status"],
      "properties": {
        "session_id": {"type": "string"},
        "thread_id": {"type": "string"},
        "understanding": {"$ref": "https://presentation-shared/schemas/extracted-understanding.schema.json"},
        "sufficiency": {"$ref": "https://presentation-shared/schemas/sufficiency-assessment.schema.json"},
        "default_proposal": {"type": "object"},
        "approved": {"type": "boolean"},
        "approval_token": {"type": ["string", "null"]},
        "actor_id": {"type": "string"},
        "tenant_id": {"type": "string"},
        "project_id": {"type": ["string", "null"]},
        "status": {"type": "string", "enum": ["needs_clarification", "ready_for_approval", "approved"]}
      }
    },
    "ApprovalRequest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["actor_id", "tenant_id"],
      "properties": {
        "actor_id": {"type": "string", "minLength": 1},
        "tenant_id": {"type": "string", "minLength": 1},
        "project_id": {"type": ["string", "null"], "minLength": 1},
        "approval_token": {"type": ["string", "null"], "minLength": 1}
      }
    },
    "ApprovalResponse": {
      "type": "object",
      "additionalProperties": false,
      "required": ["session_id", "thread_id", "actor_id", "tenant_id", "approved", "immutable_revision", "status"],
      "properties": {
        "session_id": {"type": "string"},
        "thread_id": {"type": "string"},
        "actor_id": {"type": "string"},
        "tenant_id": {"type": "string"},
        "project_id": {"type": ["string", "null"]},
        "approved": {"type": "boolean"},
        "immutable_revision": {"type": "integer", "minimum": 1},
        "status": {"const": "approved"}
      }
    },
    "QuestionListResponse": {
      "type": "object",
      "additionalProperties": false,
      "required": ["session_id", "thread_id", "actor_id", "tenant_id", "questions", "status"],
      "properties": {
        "session_id": {"type": "string"},
        "thread_id": {"type": "string"},
        "actor_id": {"type": "string"},
        "tenant_id": {"type": "string"},
        "project_id": {"type": ["string", "null"]},
        "questions": {
          "type": "array",
          "items": {"$ref": "https://presentation-shared/schemas/clarification-question.schema.json"}
        },
        "status": {"type": "string", "enum": ["questions_pending", "questions_resolved"]}
      }
    },
    "QuestionAnswerRequest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["actor_id", "tenant_id", "answer"],
      "properties": {
        "actor_id": {"type": "string", "minLength": 1},
        "tenant_id": {"type": "string", "minLength": 1},
        "project_id": {"type": ["string", "null"], "minLength": 1},
        "answer": {"type": "string", "minLength": 1}
      }
    },
    "QuestionAnswerResponse": {
      "type": "object",
      "additionalProperties": false,
      "required": ["session_id", "thread_id", "actor_id", "tenant_id", "question_id", "question", "status"],
      "properties": {
        "session_id": {"type": "string"},
        "thread_id": {"type": "string"},
        "actor_id": {"type": "string"},
        "tenant_id": {"type": "string"},
        "project_id": {"type": ["string", "null"]},
        "question_id": {"type": "string"},
        "question": {"$ref": "https://presentation-shared/schemas/clarification-question.schema.json"},
        "status": {"const": "question_answered"}
      }
    },
    "GenerateArtifactRequest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["actor_id", "tenant_id"],
      "properties": {
        "actor_id": {"type": "string", "minLength": 1},
        "tenant_id": {"type": "string", "minLength": 1},
        "project_id": {"type": ["string", "null"], "minLength": 1},
        "approval_token": {"type": ["string", "null"], "minLength": 1}
      }
    },
    "OutlineResponse": {
      "type": "object",
      "additionalProperties": false,
      "required": ["session_id", "thread_id", "actor_id", "tenant_id", "outline", "approved", "status"],
      "properties": {
        "session_id": {"type": "string"},
        "thread_id": {"type": "string"},
        "actor_id": {"type": "string"},
        "tenant_id": {"type": "string"},
        "project_id": {"type": ["string", "null"]},
        "outline": {"$ref": "https://presentation-shared/schemas/outline.schema.json"},
        "approved": {"type": "boolean"},
        "approval_token": {"type": ["string", "null"]},
        "status": {"type": "string", "enum": ["outline_draft", "outline_approved"]}
      }
    },
    "OutlineApprovalResponse": {
      "type": "object",
      "additionalProperties": false,
      "required": ["session_id", "thread_id", "actor_id", "tenant_id", "approved", "immutable_revision", "status"],
      "properties": {
        "session_id": {"type": "string"},
        "thread_id": {"type": "string"},
        "actor_id": {"type": "string"},
        "tenant_id": {"type": "string"},
        "project_id": {"type": ["string", "null"]},
        "approved": {"type": "boolean"},
        "immutable_revision": {"type": "integer", "minimum": 1},
        "status": {"const": "outline_approved"}
      }
    },
    "DeckSpecResponse": {
      "type": "object",
      "additionalProperties": false,
      "required": ["session_id", "thread_id", "actor_id", "tenant_id", "deck_spec", "status"],
      "properties": {
        "session_id": {"type": "string"},
        "thread_id": {"type": "string"},
        "actor_id": {"type": "string"},
        "tenant_id": {"type": "string"},
        "project_id": {"type": ["string", "null"]},
        "deck_spec": {"$ref": "https://presentation-shared/schemas/deck-spec.schema.json"},
        "status": {"const": "deck_spec_ready"}
      }
    }
  }
}
