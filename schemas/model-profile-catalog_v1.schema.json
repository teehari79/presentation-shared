{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Model Profile Catalog v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "kind", "profile_types", "profiles"],
  "properties": {
    "version": { "type": "string", "enum": ["v1"] },
    "kind": { "type": "string", "enum": ["model_profile_catalog"] },
    "profile_types": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "profiles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "profile_id",
          "profile_type",
          "provider",
          "model_id",
          "label",
          "expected_task_fit",
          "cpu_suitability",
          "local_dev_suitability",
          "latency_class",
          "cost_class",
          "structured_output_fit",
          "experimentation_only",
          "environment_allowlist"
        ],
        "properties": {
          "profile_id": { "type": "string", "minLength": 1 },
          "profile_type": { "type": "string", "minLength": 1 },
          "provider": { "type": "string", "minLength": 1 },
          "model_id": { "type": "string", "minLength": 1 },
          "label": { "type": "string", "minLength": 1 },
          "expected_task_fit": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "cpu_suitability": { "type": "string", "enum": ["high", "medium", "low"] },
          "local_dev_suitability": { "type": "string", "enum": ["high", "medium", "low"] },
          "latency_class": { "type": "string", "enum": ["very_fast", "fast", "medium", "slow"] },
          "cost_class": { "type": "string", "enum": ["economy", "standard", "premium"] },
          "structured_output_fit": {
            "type": "string",
            "enum": ["high", "medium", "low", "not_applicable"]
          },
          "experimentation_only": { "type": "boolean" },
          "environment_allowlist": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          }
        }
      }
    }
  }
}
