{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://presentation-shared/schemas/feedback-thumbs-event_v1.schema.json",
  "title": "Thumbs Feedback Event v1",
  "description": "Normalized thumbs up/down feedback event emitted by UI or orchestrator components.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "event_id",
    "session_id",
    "workflow_stage",
    "artifact_kind",
    "thumb",
    "created_at"
  ],
  "properties": {
    "version": {"type": "string", "const": "v1"},
    "event_id": {"type": "string", "minLength": 1},
    "session_id": {"type": "string", "minLength": 1},
    "request_id": {"type": "string", "minLength": 1},
    "artifact_id": {"type": "string", "minLength": 1},
    "artifact_kind": {"type": "string", "enum": ["understanding", "outline", "deck_spec", "rendered_output", "retrieval_result", "other"]},
    "workflow_stage": {"type": "string", "enum": ["understanding", "outline", "deck_spec", "formatting", "retrieval_reranking", "other"]},
    "thumb": {"type": "string", "enum": ["up", "down"]},
    "reason_codes": {"type": "array", "items": {"type": "string", "minLength": 1}},
    "actor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["actor_type"],
      "properties": {
        "actor_type": {"type": "string", "enum": ["user", "reviewer", "system"]},
        "actor_id": {"type": "string", "minLength": 1}
      }
    },
    "created_at": {"type": "string", "format": "date-time"},
    "metadata": {"type": "object", "additionalProperties": {"type": ["string", "number", "boolean"]}}
  }
}
