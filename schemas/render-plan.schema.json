{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://presentation-shared/schemas/render-plan.schema.json",
  "title": "RenderPlan",
  "type": "object",
  "additionalProperties": false,
  "required": ["requestId", "tenantId", "deckSpecVersion", "themeId", "slides"],
  "properties": {
    "requestId": {"type": "string", "minLength": 1},
    "tenantId": {"type": "string", "minLength": 1},
    "deckSpecVersion": {"type": "string", "minLength": 1},
    "themeId": {"type": "string", "minLength": 1},
    "slides": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/RenderSlide"}
    }
  },
  "$defs": {
    "RenderSlide": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "layoutId", "elements"],
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "layoutId": {"type": "string", "minLength": 1},
        "title": {"type": "string"},
        "notes": {"type": "string"},
        "elements": {
          "type": "array",
          "items": {"$ref": "#/$defs/RenderElement"}
        }
      }
    },
    "Box": {
      "type": "object",
      "required": ["id", "x", "y", "w", "h"],
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "x": {"type": "number"},
        "y": {"type": "number"},
        "w": {"type": "number", "exclusiveMinimum": 0},
        "h": {"type": "number", "exclusiveMinimum": 0}
      }
    },
    "RenderElement": {
      "oneOf": [
        {
          "allOf": [
            {"$ref": "#/$defs/Box"},
            {
              "type": "object",
              "additionalProperties": false,
              "required": ["type", "id", "x", "y", "w", "h"],
              "properties": {
                "type": {"const": "placeholder"},
                "id": {"type": "string"},
                "x": {"type": "number"},
                "y": {"type": "number"},
                "w": {"type": "number"},
                "h": {"type": "number"},
                "label": {"type": "string"}
              }
            }
          ]
        },
        {
          "allOf": [
            {"$ref": "#/$defs/Box"},
            {
              "type": "object",
              "additionalProperties": false,
              "required": ["type", "id", "x", "y", "w", "h", "text"],
              "properties": {
                "type": {"const": "text"},
                "id": {"type": "string"},
                "x": {"type": "number"},
                "y": {"type": "number"},
                "w": {"type": "number"},
                "h": {"type": "number"},
                "text": {"type": "string"},
                "fontSize": {"type": "number", "exclusiveMinimum": 0}
              }
            }
          ]
        },
        {
          "allOf": [
            {"$ref": "#/$defs/Box"},
            {
              "type": "object",
              "additionalProperties": false,
              "required": ["type", "id", "x", "y", "w", "h", "items"],
              "properties": {
                "type": {"const": "bullets"},
                "id": {"type": "string"},
                "x": {"type": "number"},
                "y": {"type": "number"},
                "w": {"type": "number"},
                "h": {"type": "number"},
                "items": {"type": "array", "minItems": 1, "items": {"type": "string"}},
                "fontSize": {"type": "number", "exclusiveMinimum": 0}
              }
            }
          ]
        },
        {
          "allOf": [
            {"$ref": "#/$defs/Box"},
            {
              "type": "object",
              "additionalProperties": false,
              "required": ["type", "id", "x", "y", "w", "h", "rows"],
              "properties": {
                "type": {"const": "table"},
                "id": {"type": "string"},
                "x": {"type": "number"},
                "y": {"type": "number"},
                "w": {"type": "number"},
                "h": {"type": "number"},
                "rows": {"type": "array", "minItems": 1, "items": {"type": "array", "items": {"type": "string"}}},
                "fontSize": {"type": "number", "exclusiveMinimum": 0}
              }
            }
          ]
        },
        {
          "allOf": [
            {"$ref": "#/$defs/Box"},
            {
              "type": "object",
              "additionalProperties": false,
              "required": ["type", "id", "x", "y", "w", "h", "role"],
              "properties": {
                "type": {"const": "svg"},
                "id": {"type": "string"},
                "x": {"type": "number"},
                "y": {"type": "number"},
                "w": {"type": "number"},
                "h": {"type": "number"},
                "role": {"type": "string", "enum": ["diagram", "icon"]},
                "svg": {"type": "string"},
                "assetRef": {"type": "string"},
                "fallbackText": {"type": "string"}
              }
            }
          ]
        },
        {
          "allOf": [
            {"$ref": "#/$defs/Box"},
            {
              "type": "object",
              "additionalProperties": false,
              "required": ["type", "id", "x", "y", "w", "h", "diagramSpec"],
              "properties": {
                "type": {"const": "diagram"},
                "id": {"type": "string"},
                "x": {"type": "number"},
                "y": {"type": "number"},
                "w": {"type": "number"},
                "h": {"type": "number"},
                "diagramSpec": {"type": "object"},
                "placeholderOnFailure": {"type": "boolean"}
              }
            }
          ]
        }
      ]
    }
  }
}
