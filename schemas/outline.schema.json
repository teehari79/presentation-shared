{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://presentation-shared/schemas/outline.schema.json",
  "title": "Presentation Outline",
  "type": "object",
  "additionalProperties": false,
  "required": ["session_id", "title", "sections"],
  "properties": {
    "session_id": {"type": "string"},
    "title": {"type": "string"},
    "sections": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["section_id", "heading", "slide_count"],
        "properties": {
          "section_id": {"type": "string"},
          "heading": {"type": "string"},
          "slide_count": {"type": "integer", "minimum": 1},
          "bullets": {"type": "array", "items": {"type": "string"}}
        }
      }
    }
  }
}
