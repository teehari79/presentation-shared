{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://presentation-shared/schemas/sufficiency-assessment.schema.json",
  "title": "Sufficiency Assessment",
  "type": "object",
  "additionalProperties": false,
  "required": ["is_sufficient", "rationale", "missing_critical_items"],
  "properties": {
    "is_sufficient": {"type": "boolean"},
    "rationale": {"type": "string"},
    "missing_critical_items": {"type": "array", "items": {"type": "string"}}
