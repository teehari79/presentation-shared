{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Model Fallback Policy v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "kind", "defaults", "slot_policies", "task_overrides"],
  "properties": {
    "version": { "type": "string", "enum": ["v1"] },
    "kind": { "type": "string", "enum": ["model_fallback_policy"] },
    "defaults": {
      "type": "object",
      "additionalProperties": false,
      "required": ["retry_count", "request_timeout_ms", "fail_mode", "revalidate_structured_output"],
      "properties": {
        "retry_count": { "type": "integer", "minimum": 0 },
        "request_timeout_ms": { "type": "integer", "minimum": 1 },
        "fail_mode": { "type": "string", "enum": ["fail_open", "fail_closed"] },
        "revalidate_structured_output": { "type": "boolean" }
      }
    },
    "slot_policies": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": ["retry_count", "request_timeout_ms", "fail_mode", "fallback_chain", "revalidate_structured_output"],
        "properties": {
          "retry_count": { "type": "integer", "minimum": 0 },
          "request_timeout_ms": { "type": "integer", "minimum": 1 },
          "fail_mode": { "type": "string", "enum": ["fail_open", "fail_closed"] },
          "fallback_chain": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "revalidate_structured_output": { "type": "boolean" }
        }
      }
    },
    "task_overrides": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": ["fail_mode"],
        "properties": {
          "fail_mode": { "type": "string", "enum": ["fail_open", "fail_closed"] }
        }
      }
    }
  }
}
