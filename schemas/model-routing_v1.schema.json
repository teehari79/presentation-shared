{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Model Routing v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "kind", "task_slots", "workflow_task_routes"],
  "properties": {
    "version": { "type": "string", "enum": ["v1"] },
    "kind": { "type": "string", "enum": ["task_slot_routing"] },
    "task_slots": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": ["description", "preferred_models"],
        "properties": {
          "description": { "type": "string", "minLength": 1 },
          "preferred_models": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "workflow_task_routes": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": { "type": "string", "minLength": 1 }
    }
  }
}
